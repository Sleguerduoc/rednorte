# Variables de entorno para RedNorte (Fase D1 - despliegue Railway)
# Este archivo solo documenta NOMBRES de variables, sin secretos reales.
# En local, ninguna de estas variables es necesaria: cada servicio tiene un
# fallback al valor actual de desarrollo (localhost). Definirlas aquí es solo
# referencia para cuando se configure Railway (fases D3+).

# ── URLs entre servicios (usadas por api-gateway y servicio-reasignacion) ──
SERVICIO_PACIENTES_URL=
SERVICIO_LISTA_ESPERA_URL=
SERVICIO_REASIGNACION_URL=
SERVICIO_NOTIFICACIONES_URL=

# ── Base de datos (una por servicio: pacientes, lista-espera, reasignacion, notificaciones) ──
DB_URL=
DB_USER=
DB_PASS=

# ── RabbitMQ (lista-espera, reasignacion, notificaciones) ──
RABBITMQ_HOST=
RABBITMQ_PORT=
RABBITMQ_USER=
RABBITMQ_PASS=

# ── Seguridad (api-gateway) ──
JWT_SECRET=
APP_CLIENTE_PASSWORD=

# ── CORS (api-gateway) — lista separada por comas ──
CORS_ALLOWED_ORIGINS=

# ── Frontend (servicio-notificaciones, para construir el link de confirmación) ──
FRONTEND_URL=
